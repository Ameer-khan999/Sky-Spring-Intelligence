2.awk
    
   --> awk is a utility/language designed for data extraction.Most of the time it is used to extract fields from a file or from an output.
           
            1) awk --version                                           == check the version
            2)awk '{print $1}' filename                                == list first field from a file
            3) ls -l | awk '{print $1,$2}'                             == list first and second fields of ls -l output
            4) ls -l | awk '{print $NF}'                               == last field of the output
            5) awk '/jerry/' {print}' filename                         == search for a specific word
            6) awk -F: '{print $1}' /etc/passwd                        == outputs only 1st filed of /etc/passwd file
            7) echo "ameer ameer" | awk '{$2=="khan"; print $0}'       == replace words field with new words
            8) cat file | awk '{$3="pathan"; print $0}'                == it adds 3rd filed 
            9) awk 'length($0) > 15' filename                          == get lines that have more than 15 byte size
            10) ls -l | awk '{if($NF == "seinfeld") print $0;}'        == get the field matching seinfeld in /home/akhan
            11) ls -l | awk '{print NF}'                               == gives the exact Number of fields
